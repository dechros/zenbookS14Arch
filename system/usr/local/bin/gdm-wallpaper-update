#!/bin/bash
set -e

if [[ "${1:-}" == "monitors" ]]; then
    SRC="$2"
    [[ -z "$SRC" || ! -f "$SRC" ]] && { echo "missing src file" >&2; exit 1; }
    install -d -o gdm -g gdm -m 755 /var/lib/gdm/.config
    install -o gdm -g gdm -m 644 "$SRC" /var/lib/gdm/.config/monitors.xml
    exit 0
fi

mkdir -p /etc/dconf/db/gdm.d
TMP=$(mktemp)
trap "rm -f $TMP" EXIT
cat > "$TMP"

while IFS= read -r line; do
    case "$line" in
        "["*"]" | "" | [a-z]*=*) : ;;
        *) echo "refusing line: $line" >&2; exit 1 ;;
    esac
done < "$TMP"

mv "$TMP" /etc/dconf/db/gdm.d/01-sync
trap - EXIT
dconf update
