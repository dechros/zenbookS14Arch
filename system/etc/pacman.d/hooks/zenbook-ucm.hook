[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = usr/share/alsa/ucm2/sof-soundwire/dmic.conf

[Action]
Description = Rename Digital Microphone to Microphone in UCM
When = PostTransaction
Exec = /usr/bin/sed -i s/"Digital Microphone"/"Microphone"/ /usr/share/alsa/ucm2/sof-soundwire/dmic.conf
